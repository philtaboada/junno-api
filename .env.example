# PostgreSQL (docker compose — local)
POSTGRES_USER=pm
POSTGRES_PASSWORD=pm_dev_password
POSTGRES_DB=project_management
POSTGRES_PORT=5432
DATABASE_URL=postgresql://pm:pm_dev_password@localhost:5432/project_management

# Supabase (producción — ver docs/DEPLOY.md)
# Runtime API (pooler, puerto 6543):
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
# Migraciones (direct, puerto 5432):
# DATABASE_URL=postgresql://postgres.[ref]:[password]@db.[ref].supabase.co:5432/postgres?sslmode=require

# Redis (docker compose — local)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Upstash (producción — ver docs/DEPLOY.md)
# REDIS_URL=rediss://default:XXXX@XXXX.upstash.io:6379

# API (apps/api — cuando exista)
API_PORT=3000
NODE_ENV=development
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7
# Orígenes permitidos (separados por coma). En Vercel: URL del proyecto web.
CORS_ORIGIN=http://localhost:3001
WEB_APP_URL=http://localhost:3001
# Si refresh token falla entre dominios distintos: COOKIE_SAME_SITE=none

# Web (apps/web) — local
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1
# Producción — ver docs/RAILWAY.md (API) y docs/DEPLOY.md (web Vercel)
# NEXT_PUBLIC_API_URL=https://tu-api.up.railway.app/api/v1
# NEXT_PUBLIC_REALTIME_URL=https://tu-api.up.railway.app

# Resend (emails transaccionales)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Verifica junno.online en Resend antes de enviar (DNS SPF/DKIM)
RESEND_FROM_EMAIL=no-reply@junno.online
RESEND_FROM_NAME=Junno
APP_NAME=Junno
# Solo si necesitas el enlace en pantalla además del correo (debug local):
# PASSWORD_RESET_DEV_EXPOSE_URL=true

MEILI_PORT=7700
MEILI_MASTER_KEY=pm_meili_dev_key
MEILI_URL=http://localhost:7700
# postgres (default) | meilisearch
SEARCH_ENGINE=postgres

# Automation rules (BullMQ) — requiere Redis. MVP/producción sin colas: omitir o false
# AUTOMATION_WORKER_ENABLED=true
# INTEGRATIONS_WORKER_ENABLED=true
KAPSO_API_BASE_URL=https://api.kapso.ai
KAPSO_API_KEY=
META_GRAPH_VERSION=v24.0
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_REDIRECT_URI=http://localhost:3000/api/v1/public/integrations/slack/oauth/callback

# Google OAuth — fase 2
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback
